# =============================================================================
# ITNB Hub – env.example
# Copy this file to .env and fill in the values
# Do NOT commit .env to git (it contains secrets)
# =============================================================================

# --- Development Mode (iPhone / devices on Wi-Fi) ---
# For iOS/Android on same network, replace 192.168.X.X with your machine IP
# Run: python manage.py runserver 0.0.0.0:8000

# --- Django Core Settings ---
SECRET_KEY=change-me-to-secure-random-key-min-50-chars-gunakan-ini-di-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.100

# --- Production Settings (set after SSL setup) ---
# Backend API: data.itnb.ac.id  |  Frontend (Vercel): portal.itnb.ac.id
# DEBUG=False
# ALLOWED_HOSTS=data.itnb.ac.id,YOUR_VPS_IP
# CSRF_TRUSTED_ORIGINS=https://data.itnb.ac.id,https://portal.itnb.ac.id
# FRONTEND_URL=https://portal.itnb.ac.id
# Enable only AFTER ./deploy/ssl-setup.sh succeeds:
# SECURE_SSL_REDIRECT=1
# SESSION_COOKIE_SECURE=1
# CSRF_COOKIE_SECURE=1

# --- SSL (Let's Encrypt — used by deploy/ssl-setup.sh) ---
# SSL_DOMAIN=data.itnb.ac.id
# SSL_EMAIL=admin@itnb.ac.id

# --- CORS (frontend domains — portal.itnb.ac.id on Vercel) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
# Production:
# CORS_ALLOWED_ORIGINS=https://portal.itnb.ac.id

# --- Database ---
# For LOCAL development (SQLite): leave DATABASE_URL empty or commented
# DATABASE_URL=

# For DOCKER or production (PostgreSQL):
DATABASE_URL=postgres://postgres:password@db:5432/itnb_hub

# Docker Compose credentials (when using docker-compose):
SQL_DATABASE=itnb_hub
SQL_USER=postgres
SQL_PASSWORD=password
SQL_HOST=db
SQL_PORT=5432

# --- Academic / SIS (MariaDB, read-only via PyMySQL — supports MariaDB 10.2+) ---
# Use a read-only DB user with SELECT on myitnb tables only (not root).
MYITNB_DB_HOST=db.itnb.ac.id
MYITNB_DB_PORT=3306
MYITNB_DB_NAME=myitnb
MYITNB_DB_USER=hub_readonly
MYITNB_DB_PASSWORD=change-me
# Curriculum record IDs for published score list (legacy default: 1,23,55)
MYITNB_CURRICULUM_IDS=1,23,55

# --- Cache & Message Broker (Redis) ---
# Local development (outside Docker):
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Docker Compose (use service hostname "redis", not localhost):
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- Email Configuration (Mailgun API) ---
# Required for password reset and verification emails to reach real inboxes.
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.yourdomain.com
# Address only — no spaces. Display name is set separately via MAILGUN_FROM_NAME.
DEFAULT_FROM_EMAIL=noreply@mg.yourdomain.com
MAILGUN_FROM_NAME=ITNB Hub
# Or use a quoted full header (spaces require double quotes in .env):
# DEFAULT_FROM_EMAIL="ITNB Hub <noreply@mg.yourdomain.com>"
# EU region only:
# MAILGUN_API_URL=https://api.eu.mailgun.net/v3

# Queue outbound email on Celery (recommended in production; requires celery worker)
# EMAIL_DELIVERY_ASYNC=True

# --- Logging ---
LOG_LEVEL=INFO

# --- Timezone (Django — Asia/Jakarta / WIB, UTC+7) ---
# TIME_ZONE=Asia/Jakarta

# --- Registry deploy (set by CI / deploy-registry.sh) ---
# APP_IMAGE=ghcr.io/YOUR_GITHUB_OWNER/itnb-hub-api:latest
# API_PORT=8000
